@using System.Text.Json
@model List<JsonElement>

@{
    ViewData["Title"] = "Users";
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel - Users</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        <div class="d-flex justify-content-between">
            <h2>User Management</h2>
            <form method="post" action="@Url.Action("Logout")">
                <button type="submit" class="btn btn-danger">Logout</button>
            </form>
        </div>

        <table class="table table-striped mt-3">
            <thead>
                <tr><th>Email</th><th>Name</th><th>Roles</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var id = user.GetProperty("id").GetString();
                    var email = user.GetProperty("email").GetString();
                    var name = user.GetProperty("fullName").GetString();
                    var isBanned = user.GetProperty("isBanned").GetBoolean();
                    var roles = string.Join(", ", user.GetProperty("roles").EnumerateArray().Select(r => r.GetString()));

                    <tr>
                        <td>@email</td>
                        <td>@name</td>
                        <td>@roles</td>
                        <td>@(isBanned ? "Banned" : "Active")</td>
                        <td>
                            @if (!isBanned)
                            {
                                <form method="post" action="@Url.Action("Ban")" style="display:inline">
                                    <input type="hidden" name="id" value="@id" />
                                    <button class="btn btn-sm btn-danger">Ban</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" action="@Url.Action("Unban")" style="display:inline">
                                    <input type="hidden" name="id" value="@id" />
                                    <button class="btn btn-sm btn-success">Unban</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>